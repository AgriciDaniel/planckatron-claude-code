{
  "name": "Planckatron",
  "version": "2.2.0",
  "description": "Universal Quantum Multi-Agent Orchestration System",

  "orchestration": {
    "mode": "sequential",
    "maxWorkers": 3,
    "workerTimeout": 300000,
    "retryAttempts": 2,
    "showPlanBeforeExecute": true,
    "autoDetectProjectType": true
  },

  "projectType": {
    "default": "frontend",
    "current": null,
    "supported": [
      "frontend",
      "backend",
      "fullstack",
      "automation",
      "agentic",
      "library",
      "monorepo",
      "custom"
    ],
    "configFile": "project-types.json"
  },

  "tracks": {
    "alpha": {
      "name": "Foundation",
      "description": "Primary foundation layer - varies by project type",
      "priority": 1,
      "dependsOn": []
    },
    "beta": {
      "name": "Components",
      "description": "Secondary layer - components, services, tools",
      "priority": 2,
      "dependsOn": ["alpha"]
    },
    "gamma": {
      "name": "Integration",
      "description": "Final layer - assembly, orchestration, entry",
      "priority": 3,
      "dependsOn": ["beta"]
    }
  },

  "qualityGates": {
    "typescript": {
      "enabled": true,
      "command": "npx tsc --noEmit"
    },
    "lint": {
      "enabled": false,
      "command": "npm run lint"
    },
    "build": {
      "enabled": true,
      "command": "npm run build"
    },
    "test": {
      "enabled": false,
      "command": "npm run test"
    }
  },

  "designTokens": {
    "extractFromScreenshot": true,
    "defaults": {
      "colors": {
        "background": "#1a1a2e",
        "backgroundSecondary": "#252542",
        "backgroundTertiary": "#16213e",
        "text": "#ffffff",
        "textMuted": "#9ca3af",
        "accent": "#e94560",
        "accentHover": "#d63d56",
        "success": "#10b981",
        "warning": "#f59e0b",
        "error": "#ef4444",
        "border": "#374151"
      },
      "spacing": {
        "xs": "0.25rem",
        "sm": "0.5rem",
        "md": "1rem",
        "lg": "1.5rem",
        "xl": "2rem",
        "2xl": "3rem"
      },
      "borderRadius": {
        "sm": "0.25rem",
        "md": "0.375rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "2xl": "1rem",
        "full": "9999px"
      }
    }
  },

  "git": {
    "createBranches": false,
    "branchPrefix": "planck/",
    "commitPrefix": "[PLANCK]",
    "autoCommit": false
  },

  "state": {
    "directory": ".planckatron/state",
    "currentFile": "current.json",
    "historyFile": "history.json"
  },

  "logging": {
    "directory": ".planckatron/logs",
    "verbose": true
  }
}
